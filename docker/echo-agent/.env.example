# Echo Agent Docker Stack
AGENT_POSTGRES_PASSWORD=echo_agent
AGENT_AUTH_TOKEN=

# Web search — get free API key at https://tavily.com (1,000 credits/month, no card required)
TAVILY_API_KEY=

# Optional overrides:
# ECHO_AGENT_IMAGE=ghcr.io/desu777/echoclaw/echo-agent:latest
# AGENT_PORT=4201
#
# Manual docker compose users should set ECHO_CONFIG_DIR explicitly:
# Linux:   ECHO_CONFIG_DIR=~/.config/echoclaw
# macOS:   ECHO_CONFIG_DIR=~/Library/Application\ Support/echoclaw
# Windows: ECHO_CONFIG_DIR=%APPDATA%\echoclaw
